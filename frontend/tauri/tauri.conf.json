{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "vstable",
  "version": "0.5.5",
  "identifier": "com.rust17.vstable",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run build:sidecar && npm run dev-frontend",
    "beforeBuildCommand": "npm run build:sidecar && npm run build-frontend"
  },
  "app": {
    "windows": [
      {
        "title": "vstable",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/vstable-engine"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
